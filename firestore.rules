rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read:   if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read:   if request.auth.uid == resource.data.patientId || isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.patientId == request.auth.uid;
      allow update: if isAdmin()
                    || (request.auth.uid == resource.data.patientId
                        && request.resource.data.status == 'Cancelled');
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read:  if request.auth.uid == resource.data.patientId || isAdmin();
      allow write: if isAdmin();
    }

    match /packages/{packageId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Email queue: patients/admin can write (enqueue), nobody can read from client
    // Only the Firebase Admin SDK (GitHub Actions service account) reads this collection
    match /mailQueue/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Email config (reminder hours, etc.) — admin writes, nobody reads from client
    match /config/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
