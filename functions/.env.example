# ─── Gmail OAuth2 credentials ────────────────────────────────────────────
# Follow the setup guide in SETUP_EMAIL.md to obtain these values.
# NEVER commit the actual .env file – it is git-ignored.

GMAIL_USER=sruthi_kandaswamy@celltalediagnostics.com
GMAIL_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret
GMAIL_REFRESH_TOKEN=1//your-refresh-token-here

# ─── App config ───────────────────────────────────────────────────────────
# Public URL used in email CTA buttons
APP_URL=https://celltalediagnostics-8f817.web.app
# Visible "From" address on all outgoing emails
# Must be configured as a "Send mail as" alias in GMAIL_USER's Gmail settings
FROM_EMAIL=care@celltalediagnostics.com
# Contact email shown to patients in email templates (can differ from FROM_EMAIL)
SUPPORT_EMAIL=care@celltalediagnostics.com
